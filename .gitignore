backend/sessions.json

# ── Node ──────────────────────────────────────────────────────────────────────
frontend/node_modules/
frontend/dist/
frontend/dist-ssr/
*.local

# ── Logs ──────────────────────────────────────────────────────────────────────
logs/
*.log
npm-debug.log*

# ── OS ────────────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db

# ── Editor ────────────────────────────────────────────────────────────────────
.vscode/
.idea/

